{
    "version": 1.0,
    "name": "PickingShader",
    "renderpass": "picking",

    "stages": 
    {
        "vertex": "Builtin.PickingShader.vert.glsl",
        "fragment": "Builtin.PickingShader.frag.glsl"
    },

    "isUsingInstance": false,
    "isUsingLocal": true,

  "attributes": [
    {
      "name": "in_position",
      "type": "vec3"
    },
    {
      "name": "in_normal",
      "type": "vec3"
    },
    {
      "name": "in_texcoord",
      "type": "vec2"
    },
    {
      "name": "in_tangent",
      "type": "vec3"
    },
    {
      "name": "in_bitangent",
      "type": "vec3"
    }
  ],

  "uniforms": [
    {
      "name": "projection",
      "type": "mat4",
      "scope": "global"
    },
    {
      "name": "view",
      "type": "mat4",
      "scope": "global"
    },
    {
      "name": "model",
      "type": "mat4",
      "scope": "local"
    },
    {
      "name": "object_id",
      "type": "uint32",
      "scope": "local"
    }
  ]
}
